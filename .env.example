# Google OAuth — create credentials at https://console.cloud.google.com
# APIs & Services > Credentials > Create OAuth 2.0 Client ID (Web application)
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# Redirect URI — must match exactly what's set in Google Cloud Console
# Local:      http://localhost:3000/auth/google/callback
# Production: https://yourdomain.com/auth/google/callback
OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Resend email — sign up at https://resend.com, verify your domain, then create an API key
RESEND_API_KEY=re_your_api_key_here
# Must be an address on your verified Resend domain
RESEND_FROM=noreply@realworklabs.com
